# ──────────────────────────────────────────────────────────────────────────────
# go-drp environment configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Required: shared secret that all clients must send in the X-Proxy-Token header.
# Use a strong random value, e.g.: openssl rand -hex 32
# Omit (or ignored) when MTLS_CA_FILE / MTLS_CERT_FILE / MTLS_KEY_FILE are set
# and the client presents a valid mTLS certificate.
PROXY_TOKEN=change-me-use-a-strong-random-value

# Optional: port the gateway listens on. Default: 8080
PORT=8080

# Optional: comma-separated list of allowed client IP addresses.
# Leave empty to allow all client IPs.
# Example: WHITELIST_IP=203.0.113.10,203.0.113.11
WHITELIST_IP=

# Optional: comma-separated allowlist of upstream hostnames the gateway may
# proxy to (SSRF protection). When set, ONLY these hosts are permitted.
# When empty, a built-in blocklist blocks private/reserved IP ranges and
# cloud-metadata endpoints (127.x, 10.x, 192.168.x, 169.254.x, etc.).
# Example: ALLOWED_UPSTREAM_HOSTS=api.stripe.com,api.github.com
ALLOWED_UPSTREAM_HOSTS=

# Optional: set to "true" or "1" ONLY when the gateway runs behind a trusted
# reverse proxy (Nginx, Caddy, …) that controls the X-Real-IP and
# X-Forwarded-For headers. Leaving this false when the gateway is
# internet-facing prevents attackers from spoofing their IP to bypass
# WHITELIST_IP checks.
TRUST_PROXY_HEADERS=false

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Optional: maximum requests per second allowed from a single client IP.
# 0 (default) disables rate limiting.
# Example: RATE_LIMIT_RPS=10
RATE_LIMIT_RPS=0

# Optional: burst size for the token-bucket rate limiter.
# When 0, defaults to RATE_LIMIT_RPS (no burst beyond the steady rate).
# Example: RATE_LIMIT_BURST=20
RATE_LIMIT_BURST=0

# ── Per-upstream timeouts ─────────────────────────────────────────────────────
# Optional: max time to establish a TCP connection to an upstream server.
# Accepts Go duration strings (e.g. "5s", "500ms"). Default: 10s.
UPSTREAM_DIAL_TIMEOUT=10s

# Optional: max time to wait for the upstream to send response headers after
# the request is written. Accepts Go duration strings. Default: 30s.
UPSTREAM_RESPONSE_TIMEOUT=30s

# ── Mutual TLS (mTLS) ─────────────────────────────────────────────────────────
# Optional: when all three are set, the gateway requires clients to present
# a TLS certificate signed by the specified CA. Authenticated clients do not
# need to supply the X-Proxy-Token header.
# MTLS_CA_FILE   – path to the PEM-encoded CA certificate that signed client certs
# MTLS_CERT_FILE – path to the server's PEM-encoded TLS certificate
# MTLS_KEY_FILE  – path to the server's PEM-encoded private key
#
# Example:
# MTLS_CA_FILE=/etc/go-drp/ca.pem
# MTLS_CERT_FILE=/etc/go-drp/server.pem
# MTLS_KEY_FILE=/etc/go-drp/server-key.pem
MTLS_CA_FILE=
MTLS_CERT_FILE=
MTLS_KEY_FILE=

