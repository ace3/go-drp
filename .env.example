# ──────────────────────────────────────────────────────────────────────────────
# go-drp environment configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Required: shared secret that all clients must send in the X-Proxy-Token header.
# Use a strong random value, e.g.: openssl rand -hex 32
PROXY_TOKEN=change-me-use-a-strong-random-value

# Optional: port the gateway listens on. Default: 8080
PORT=8080

# Optional: comma-separated list of allowed client IP addresses.
# Leave empty to allow all client IPs.
# Example: WHITELIST_IP=203.0.113.10,203.0.113.11
WHITELIST_IP=

# Optional: comma-separated allowlist of upstream hostnames the gateway may
# proxy to (SSRF protection). When set, ONLY these hosts are permitted.
# When empty, a built-in blocklist blocks private/reserved IP ranges and
# cloud-metadata endpoints (127.x, 10.x, 192.168.x, 169.254.x, etc.).
# Example: ALLOWED_UPSTREAM_HOSTS=api.stripe.com,api.github.com
ALLOWED_UPSTREAM_HOSTS=

# Optional: set to "true" or "1" ONLY when the gateway runs behind a trusted
# reverse proxy (Nginx, Caddy, …) that controls the X-Real-IP and
# X-Forwarded-For headers. Leaving this false when the gateway is
# internet-facing prevents attackers from spoofing their IP to bypass
# WHITELIST_IP checks.
TRUST_PROXY_HEADERS=false

